# ============= Application =============
APP_NAME=EV Efficiency Optimizer
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ============= Server =============
HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ============= Database =============
# Development (SQLite)
DATABASE_URL=sqlite:///./test.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql://username:password@localhost:5432/evoptimizer

# Database Details (for docker-compose)
DB_USER=evoptimizer
DB_PASSWORD=change_this_password
DB_NAME=evoptimizer

# ============= Security =============
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============= CORS =============
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
CORS_CREDENTIALS=true

# ============= API =============
API_TITLE=EV Efficiency Optimizer API
API_DESCRIPTION=AI-powered electric vehicle driving efficiency optimization
API_VERSION=1.0.0
API_PREFIX=/api

# ============= ML Models =============
MODELS_PATH=app/ml_models
EFFICIENCY_MODEL_PATH=app/ml_models/efficiency_model.pkl
ANOMALY_MODEL_PATH=app/ml_models/anomaly_detector.pkl
FEATURES_SCALER_PATH=app/ml_models/features_scaler.pkl

# ============= Logging =============
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============= Redis (Optional) =============
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============= Frontend API =============
VITE_API_URL=http://localhost:8000/api
VITE_DEBUG=true

# ============= Third-party Services =============
# Sentry (Error tracking)
SENTRY_DSN=

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ============= OpenWeather API (Optional) =============
OPENWEATHER_API_KEY=

# ============= Google Maps API (Optional) =============
GOOGLE_MAPS_API_KEY=

# ============= Monitoring & Analytics =============
# Prometheus metrics
PROMETHEUS_ENABLED=false

# Datadog (optional)
DATADOG_API_KEY=
DATADOG_ENABLED=false

# ============= Rate Limiting =============
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ============= File Upload =============
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,xlsx,csv

# ============= Feature Flags =============
ENABLE_NOTIFICATIONS=true
ENABLE_RECOMMENDATIONS=true
ENABLE_ROUTE_OPTIMIZATION=true
ENABLE_SOCIAL_FEATURES=false

# ============= Database Backup =============
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=7

# ============= Production Settings =============
# Nginx
NGINX_ENABLED=false
CERTIFICATE_PATH=/etc/nginx/ssl/cert.pem
CERTIFICATE_KEY_PATH=/etc/nginx/ssl/key.pem

# Deployment
DEPLOYMENT_ENV=docker
DEPLOYMENT_REGION=us-east-1

# ============= Development Only =============
# Hot reload
HOT_RELOAD=true

# Database initialization
INIT_DB=false
SEED_DATA=false

# Notes:
# 1. Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. For production, use a strong database password
# 3. Set DEBUG=false in production
# 4. Configure CORS_ORIGINS for your domain
# 5. Use environment-specific .env files (.env.development, .env.production)
